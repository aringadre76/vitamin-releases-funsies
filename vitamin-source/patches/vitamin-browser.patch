+        window.VitaminPoisonBridge.saveSettings(newSettings);
+      }
+    });
+
+    // Init on load or when bridge becomes available
+    if (window.VitaminPoisonBridge) {
+      initSettings();
+    }
+
+    // Expose for parent to call
+    window.initSettings = initSettings;
+  </script>
+</body>
+</html>

