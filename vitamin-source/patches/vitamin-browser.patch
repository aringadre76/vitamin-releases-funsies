+  receiveMessage(message) {
+    switch (message.name) {
+      case "VitaminStartPage:UpdateIndicator":
+        this.updateIndicator(message.data.active);
+        break;
+    }
+    return null;
+  }
+
+  updateIndicator(active) {
+    try {
+      if (!this.document || !this.document.documentElement) return;
